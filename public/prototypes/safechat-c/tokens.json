{
  "$schema": "https://schemas.tokens.studio/draft/2022-05-04/schema.json",
  "global": {
    "color": {
      "primary": { "$value": "#4B7BE5", "$type": "color", "$description": "Primary blue — buttons, active borders, links" },
      "primary-light": { "$value": "#EEF3FC", "$type": "color", "$description": "Primary tint — selected card bg, tag bg" },
      "bg": { "$value": "#F8F9FB", "$type": "color", "$description": "App background" },
      "surface": { "$value": "#FFFFFF", "$type": "color", "$description": "Card and input surface" },
      "text-primary": { "$value": "#1C1C28", "$type": "color", "$description": "Primary body text" },
      "text-secondary": { "$value": "#6B7280", "$type": "color", "$description": "Secondary / descriptive text" },
      "text-muted": { "$value": "#9CA3AF", "$type": "color", "$description": "Placeholder, hint text" },
      "border": { "$value": "#E5E7EB", "$type": "color", "$description": "Default border color" },
      "tier-off": { "$value": "#9CA3AF", "$type": "color", "$description": "Off tier dot and badge text" },
      "tier-balanced": { "$value": "#F59E0B", "$type": "color", "$description": "Balanced tier amber" },
      "tier-strict": { "$value": "#EF4444", "$type": "color", "$description": "Strict tier red" },
      "success": { "$value": "#10B981", "$type": "color", "$description": "Completion state green" },
      "blocked-bg": { "$value": "#FFF7ED", "$type": "color", "$description": "Blocked chat card background" },
      "blocked-border": { "$value": "#F97316", "$type": "color", "$description": "Blocked card left border and header" },
      "text-dark": { "$value": "#1C1C28", "$type": "color", "$description": "Dark CTA button background" }
    },
    "border-radius": {
      "card": { "$value": "12px", "$type": "dimension" },
      "button": { "$value": "12px", "$type": "dimension" },
      "badge": { "$value": "8px", "$type": "dimension" },
      "tag": { "$value": "6px", "$type": "dimension" },
      "phone": { "$value": "50px", "$type": "dimension" }
    },
    "shadow": {
      "card": { "$value": "0 1px 4px rgba(0,0,0,0.09)", "$type": "shadow" },
      "cta-blue": { "$value": "0 4px 16px rgba(75,123,229,0.35)", "$type": "shadow" },
      "phone": { "$value": "0 0 0 8px #1A1A28, 0 32px 80px rgba(0,0,0,0.32)", "$type": "shadow" }
    },
    "typography": {
      "font-family": { "$value": "DM Sans", "$type": "fontFamily" },
      "font-size-xs": { "$value": "9px", "$type": "dimension" },
      "font-size-sm": { "$value": "11px", "$type": "dimension" },
      "font-size-base": { "$value": "13px", "$type": "dimension" },
      "font-size-md": { "$value": "15px", "$type": "dimension" },
      "font-size-lg": { "$value": "20px", "$type": "dimension" },
      "font-size-xl": { "$value": "24px", "$type": "dimension" },
      "font-size-display": { "$value": "26px", "$type": "dimension" }
    },
    "spacing": {
      "xs": { "$value": "4px", "$type": "dimension" },
      "sm": { "$value": "8px", "$type": "dimension" },
      "md": { "$value": "14px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" },
      "2xl": { "$value": "32px", "$type": "dimension" }
    }
  }
}
